# env.example
# Configuration template for saskan-lore.
# Copy to env.local and set real values. Never commit env.local.

# ----------------------------
# Application
# ----------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ----------------------------
# Database (R1)
# ----------------------------
# DATABASE_URL is set automatically by scripts/setenv.sh from SASKAN_VAR_DIR.
# Do not set it here — it will be overridden at runtime.
# Format: sqlite:////<absolute-path>/saskan_lore.db

# In-memory DB for pytest fixtures — do not change.
TEST_DATABASE_URL=sqlite:///:memory:

# ----------------------------
# OpenAI (R3: Extraction)
# ----------------------------
# Required by extractor.py. Load from the OS environment — do not paste the
# real key here.
# To set: export OPENAI_API_KEY=sk-...
OPENAI_API_KEY=

# Model used for extraction. gpt-4o is the R3 default.
OPENAI_MODEL=gpt-4o

# ----------------------------
# Local LLM (R5+: Retrieval)
# ----------------------------
# LOCAL_MODEL_PATH and LLAMA_N_GPU_LAYERS are set automatically by
# scripts/setenv.sh based on the detected platform (uname -s). See ADR-008.
# Values below are ignored at runtime — kept here for documentation only.
#
# Mac M2 Pro:  ~/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf  gpu_layers=-1
# Dell Linux:  ~/models/Qwen2.5-3B-Instruct-Q4_K_M.gguf  gpu_layers=0
#
# To override: edit the model filenames in scripts/setenv.sh directly.
LOCAL_MODEL_PATH=
LLAMA_N_GPU_LAYERS=

# ----------------------------
# Paths
# ----------------------------
# Source lore PDFs (relative to project root).
LORE_TEXTS_DIR=./saskan_lore/data/lore_texts

# Runtime data directory — machine-local, outside the Dropbox-synced repo.
# Defaults to $HOME/.local/share/saskan-lore/ if not set here.
# Set this only if you want to override the default location.
# DATABASE_URL, REVIEWED_DIR, and LOG_DIR are all derived from this by setenv.sh.
# SASKAN_VAR_DIR=
