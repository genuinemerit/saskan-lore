# env.example
# Configuration template for saskan-lore.
# Copy to env.local and set real values. Never commit env.local.

# ----------------------------
# Application
# ----------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ----------------------------
# Database (R1)
# ----------------------------
# SQLite path used by SQLAlchemy and Alembic.
# Relative to the project root, or use an absolute path.
DATABASE_URL=sqlite:///./data/saskan_lore.db

# In-memory DB for pytest fixtures — do not change.
TEST_DATABASE_URL=sqlite:///:memory:

# ----------------------------
# OpenAI (R3: Extraction)
# ----------------------------
# Required by extractor.py. Load from the OS environment — do not paste the
# real key here.
# To set: export OPENAI_API_KEY=sk-...
OPENAI_API_KEY=

# Model used for extraction. gpt-4o is the R3 default.
OPENAI_MODEL=gpt-4o

# ----------------------------
# Local LLM (R5+: Retrieval)
# ----------------------------
# Absolute path to a GGUF model file for local llama.cpp inference.
# Target: a 3B-class instruct model (e.g. Qwen 2.5 3B or Llama 3 3B).
# Example: /home/user/models/qwen2.5-3b-instruct-q4_k_m.gguf
LOCAL_MODEL_PATH=

# ----------------------------
# Paths
# ----------------------------
# Source lore PDFs (relative to project root).
LORE_TEXTS_DIR=./saskan-lore/data/lore_texts

# Staging area for reviewed extraction output (JSON files).
REVIEWED_DIR=./data/reviewed

# Log output directory.
LOG_DIR=./logs
