# --- Python bytecode / artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Packaging / build outputs ---
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# --- Tests / coverage ---
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
nosetests.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.benchmarks/

# Test output: generated result files (inspectable after a run, not versioned)
tests/output/*
!tests/output/.gitkeep

# --- Logs & debug ---
log/
debug/
*.log
!saskan_lore/infra/log/

# --- Environments ---
# Ignore real environment config/secrets
.env
.env.*
/env/

# Keep the example template committed
!.env.example

# Project env files (env.local, env.test, env.prod) — never commit
saskan_lore/infra/config/env.local
saskan_lore/infra/config/env.test
saskan_lore/infra/config/env.prod

.venv
venv/
ENV/
env.bak/
venv.bak/

# --- Editors / IDE ---
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject

# --- Jupyter / IPython ---
.ipynb_checkpoints
profile_default/
ipython_config.py

# --- Docs ---
docs/_build/
site/

# --- Databases ---
# SQLite local dev DB files should not be versioned.
# Covers all common SQLite extensions and WAL/journal/shm sidecars.
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.sqlite3-journal
*.db-wal
*.sqlite-wal
*.sqlite3-wal
*.db-shm
*.sqlite-shm
*.sqlite3-shm

# --- Postgres (local Docker volumes / scratch data) ---
# Ignore common local volume dirs you might map in docker-compose.
pgdata/
postgres-data/
postgres_data/
.data/pg/
data/pg/
# Optional: dumps directory for ad-hoc exports; keep schema/SQL in versioned paths instead.
dumps/
*.dump
*.bak
*.backup

# --- System cruft ---
.DS_Store
Thumbs.db

# --- Runtime output dirs (generated at runtime, not versioned) ---
/logs/
/data/reviewed/

# --- Alembic ---
# Migration scripts in alembic/versions/ ARE committed — do not ignore them.
# Only ignore compiled bytecode inside the alembic tree.
alembic/versions/__pycache__/

# --- Project-specific scratch areas ---
# Dont' put any assets into the repo
assets/
# Except for *.manifest.json files and thumbs
!/assets/*.manifest.json
!/assets/v0/thumbs/**
lab/
legacy/
snips/
draw/

# --- Configs (be careful) ---
# Avoid blanket ignoring of *.conf to prevent accidental loss of real config.
# Instead, ignore only secret overrides:
*.local.conf
*.override.conf

# --- Tools (optional but common) ---
.ruff_cache/
.pyre/
.mypy_cache/
.dmypy.json
dmypy.json

# --- Keep Poetry lockfile (application) ---
# (Intentionally NOT ignored) poetry.lock
